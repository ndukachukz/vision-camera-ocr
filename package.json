{
  "name": "@chuksdengr/vision-camera-ocr",
  "version": "1.1.1",
  "description": "A React Native Vision Camera plugin for real-time OCR (Optical Character Recognition). This package enables seamless integration of on-device OCR by using Google ML Kit on Android and Apple's Vision Framework on iOS. It provides fast, efficient, and cross-platform text recognition capabilities directly within Vision Camera for React Native apps.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.tsx",
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "nitrogen/generated",
    "*.podspec",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "test": "jest",
    "typecheck": "tsc",
    "lint": "biome check .",
    "clean": "del-cli android/build lib",
    "nitrogen": "nitrogen",
    "prepare": "bob build",
    "release": "release-it --only-version",
    "format": "biome format --write ."
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "react-native-vision-camera",
    "vision-camera",
    "ocr",
    "text-recognition",
    "text-detection",
    "chuksdengr"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ndukachukz/vision-camera-ocr.git"
  },
  "author": "ndukachukz (https://github.com/ndukachukz)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ndukachukz/vision-camera-ocr/issues"
  },
  "homepage": "https://github.com/ndukachukz/vision-camera-ocr#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@evilmartians/lefthook": "^1.5.0",
    "@react-native-community/cli": "15.0.0-alpha.2",
    "@react-native/babel-preset": "0.81.5",
    "@release-it/conventional-changelog": "^9.0.2",
    "@types/jest": "^29.5.5",
    "@types/react": "^19.0.0",
    "commitlint": "^19.6.1",
    "del-cli": "^5.1.0",
    "jest": "^29.7.0",
    "nitrogen": "^0.35.6",
    "react": "19.0.0",
    "react-native": "0.81.5",
    "react-native-builder-bob": "^0.40.11",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-vision-camera": "^5.0.0",
    "release-it": "^17.10.0",
    "turbo": "^1.10.7",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-nitro-modules": "*",
    "react-native-vision-camera": ">= 5"
  },
  "packageManager": "bun@1.2.22",
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "create-react-native-library": {
    "languages": "kotlin-objc",
    "type": "turbo-module",
    "version": "0.50.3"
  }
}
